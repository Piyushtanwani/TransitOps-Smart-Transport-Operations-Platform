# ======= TransitOps environment (copy to .env — never commit .env) =======

# --- Database (docker-compose service `db`) ---
DATABASE_URL=postgresql+psycopg2://transitops:transitops@localhost:5432/transitops
DATABASE_URL_TEST=postgresql+psycopg2://transitops:transitops@localhost:5432/transitops_test

# --- Auth ---
# Minimum 32 characters. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-random-48-char-secret-before-first-run
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7

# --- AI (OpenRouter) — app runs fine with key unset; AI endpoints return 503 AI_DISABLED ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- API ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend (Vite exposes only VITE_-prefixed vars) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
